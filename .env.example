# fal.ai (Nano Banana Pro - image generation)
FAL_KEY=

# Anthropic (Claude - copy generation + intent classification)
ANTHROPIC_API_KEY=

# OpenAI (Whisper - voice note transcription)
OPENAI_API_KEY=

# GoHighLevel (WhatsApp + social publishing)
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_WEBHOOK_SECRET=

# Google (Places API - GMB photo scraping)
GOOGLE_PLACES_API_KEY=

# Supabase (PostgreSQL database)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=price_xxx

# App
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
WEBHOOK_PATH=/webhooks/ghl

# Operational tuning
MESSAGE_THROTTLE_MS=2000
FAL_CONCURRENCY_LIMIT=3
PUBLISH_BUFFER_MINUTES=15
AUTOPILOT_REMINDER_MINUTES=90
AUTOPILOT_PUBLISH_MINUTES=120
JOB_POLLER_INTERVAL_MS=60000
WEBHOOK_WORKER_INTERVAL_MS=5000
